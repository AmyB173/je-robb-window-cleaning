RewriteEngine On

# Force www version (redirect non-www to www)
RewriteCond %{HTTP_HOST} ^jerobb\.co\.uk$ [NC]
RewriteRule ^(.*)$ https://www.jerobb.co.uk/$1 [R=301,L]

# Redirect old .php URLs to clean URLs
RewriteCond %{REQUEST_URI} ^(.+)\.php$
RewriteRule ^ %1 [R=301,L]

# Serve .php files for clean URL requests
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^\.]+)$ $1.php [NC,L]